<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Корзина — HomeBuild</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .checkout-form {
      max-width: 600px;
      margin: 2rem auto;
      padding: 2rem;
      border: 1px solid #e8e8e8;
      border-radius: 8px;
      display: none;
    }
    .checkout-form.active {
      display: block;
    }
    .checkout-step {
      margin-bottom: 2rem;
      padding: 1.5rem;
      display: none;
    }
    .checkout-step.active {
      display: block;
    }
    .checkout-step h3 {
      margin-bottom: 1rem;
      font-weight: 300;
      font-size: 1.2rem;
    }
    .form-group {
      margin-bottom: 1rem;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #e8e8e8;
      border-radius: 4px;
      font-size: 1rem;
      font-family: Arial, sans-serif;
    }
    .form-group textarea {
      min-height: 96px;
    }
    .form-group input[type="date"] {
      height: 46px;
    }
    .success-message {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: #fff;
      padding: 3rem;
      border: 1px solid #e8e8e8;
      border-radius: 8px;
      text-align: center;
      z-index: 2000;
      max-width: 400px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      display: none;
    }
    .success-message.active {
      display: block;
    }
    .success-message h2 {
      margin-bottom: 1rem;
      font-size: 1.5rem;
    }
    .success-message p {
      font-size: 1.1rem;
      color: #666;
    }
    .buttons {
      display: flex;
      gap: 1rem;
      justify-content: space-between;
    }
    .buttons .btn,
    .buttons .btn-secondary {
      min-width: 180px;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      text-align: center;
    }
    .btn-secondary {
      background: transparent;
      color: #d35400;
      border: 2px solid #d35400;
      cursor: pointer;
    }
    @media (max-width: 768px) {
      .checkout-form {
        max-width: 360px;
        padding: 1rem;
      }
      .checkout-step {
        padding: 0.9rem;
        margin-bottom: 1rem;
      }
      .buttons .btn,
      .buttons .btn-secondary {
        min-width: 0;
        width: 100%;
      }
      .success-message {
        width: 280px;
        min-height: 280px;
        max-width: 280px;
        padding: 1.2rem;
        display: none;
      }
      .success-message.active {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }
      .success-message h2 {
        font-size: 1.2rem;
      }
      .success-message p {
        font-size: 0.9rem;
      }
    }
    .error-message {
      color: #d32f2f;
      font-size: 0.875rem;
      margin-top: 0.25rem;
      display: none;
    }
    .error-message.show {
      display: block;
    }
    .form-group.error input,
    .form-group.error textarea,
    .form-group.error select {
      border-color: #d32f2f;
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="section">
    <div class="container">
      <h2 class="section-title">Корзина</h2>
      
      <% if (cartItems.length === 0) { %>
        <div style="text-align: center; padding: 3rem 0;">
          <p style="font-size: 1.2rem; color: #666; margin-bottom: 2rem;">Ваша корзина пуста</p>
          <a href="/catalog" class="btn">Перейти в каталог</a>
        </div>
      <% } else { %>
        <div class="cart-items">
          <% cartItems.forEach(item => { %>
            <div class="cart-item">
              <div class="cart-item-image">
                <img src="<%= item.image_url %>" alt="<%= item.name %>">
              </div>
              <div class="cart-item-content">
                <h3><%= item.name %></h3>
                <p class="cart-item-price"><%= item.price %> ₽ за шт.</p>
                <div class="cart-item-controls">
                  <div class="quantity-controls">
                    <label>Количество:</label>
                    <input type="number" 
                           value="<%= item.quantity %>" 
                           min="1" 
                           max="<%= item.stock %>"
                           onchange="updateQuantity(<%= item.id %>, this.value)">
                  </div>
                  <div class="cart-item-total">
                    <p class="cart-item-sum"><strong><%= (item.price * item.quantity).toFixed(2) %> ₽</strong></p>
                    <button class="remove-btn" onclick="removeFromCart(<%= item.id %>)">Удалить</button>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="cart-summary">
          <h3>Итого к оплате</h3>
          <div class="total"><%= total.toFixed(2) %> ₽</div>
          <% if (user) { %>
            <button class="btn" onclick="showCheckoutForm()">Оформить заказ</button>
          <% } else { %>
            <p style="margin-bottom: 1rem; color: #666;">Для оформления заказа необходимо войти в систему</p>
            <a href="/login" class="btn">Войти</a>
          <% } %>
        </div>

        <% if (user) { %>
          <div id="checkout-form" class="checkout-form">
            <div class="checkout-step active" id="address-step">
              <h3>Адрес доставки</h3>
              <div class="form-group" id="address-group">
                <label for="address">Адрес доставки *</label>
                <textarea id="address" placeholder="Укажите полный адрес доставки"></textarea>
                <div class="error-message" id="address-error">Пожалуйста, укажите адрес</div>
              </div>
              <div class="form-group" id="phone-group">
                <label for="phone">Телефон *</label>
                <input type="text" id="phone" placeholder="+7 (___) ___-__-__" inputmode="tel" autocomplete="tel">
                <div class="error-message" id="phone-error">Введите телефон в формате +7 (999) 999-99-99</div>
              </div>
              <div class="form-group" id="date-group">
                <label for="deliveryDate">Дата доставки *</label>
                <input type="date" id="deliveryDate">
                <div class="error-message" id="date-error">Пожалуйста, выберите дату</div>
              </div>
              <div class="buttons">
                <button type="button" class="btn-secondary" onclick="hideCheckoutForm()">Отмена</button>
                <button type="button" class="btn" onclick="confirmAddress()">Подтвердить адрес</button>
              </div>
            </div>

            <div class="checkout-step" id="payment-step">
              <h3>Выбор способа оплаты</h3>
              <div class="form-group" id="payment-group">
                <label for="payment-method">Способ оплаты</label>
                <select id="payment-method">
                  <option value="">Выберите способ оплаты</option>
                  <option value="card">Банковская карта</option>
                  <option value="cash">Наличные курьеру</option>
                  <option value="online">Электронный платеж</option>
                </select>
                <div class="error-message" id="payment-error">Пожалуйста, выберите способ оплаты</div>
              </div>
              <div class="form-group" id="card-details" style="display: none;">
                <label for="card-number">Номер карты</label>
                <input type="text" id="card-number" placeholder="0000 0000 0000 0000" inputmode="numeric" autocomplete="cc-number">
                <div class="error-message" id="card-number-error">Номер карты должен содержать 16 цифр</div>
                <label for="card-expiry" style="margin-top: 1rem;">Срок действия</label>
                <input type="text" id="card-expiry" placeholder="MM/YY" inputmode="numeric" autocomplete="cc-exp">
                <div class="error-message" id="card-expiry-error">Укажите корректный срок (год не меньше текущего)</div>
                <label for="card-cvc" style="margin-top: 1rem;">CVC</label>
                <input type="text" id="card-cvc" placeholder="000" inputmode="numeric" autocomplete="cc-csc">
                <div class="error-message" id="card-cvc-error">CVC должен содержать 3 цифры</div>
              </div>
              <div class="buttons">
                <button type="button" class="btn-secondary" onclick="backToAddress()">Назад</button>
                <button type="button" class="btn" onclick="confirmPayment()">Оформить заказ</button>
              </div>
            </div>
          </div>

          <div class="success-message" id="success-message">
            <h2>Спасибо за заказ!</h2>
            <p>Ваш заказ успешно оформлен</p>
            <p style="margin-top: 1.5rem; color: #999;">Номер заказа: <strong id="order-id"></strong></p>
            <a href="/" class="btn" style="margin-top: 1.5rem;">На главную</a>
          </div>
        <% } %>
      <% } %>
    </div>
  </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    async function updateQuantity(flowerId, quantity) {
      try {
        const response = await fetch('/cart/update', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ flowerId, quantity: parseInt(quantity) })
        });
        
        const data = await response.json();
        
        if (data.success) {
          location.reload();
        }
      } catch (error) {
        // Ошибка при обновлении количества
      }
    }

    async function removeFromCart(flowerId) {
      try {
        const response = await fetch('/cart/remove', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ flowerId })
        });
        
        const data = await response.json();
        
        if (data.success) {
          const cartBadge = document.getElementById('cart-count');
          cartBadge.textContent = data.cartCount;
          location.reload();
        }
      } catch (error) {
        // Ошибка при удалении товара
      }
    }

    function showCheckoutForm() {
      document.getElementById('checkout-form').classList.add('active');
      document.getElementById('checkout-form').scrollIntoView({ behavior: 'smooth' });
    }

    function hideCheckoutForm() {
      document.getElementById('checkout-form').classList.remove('active');
      document.getElementById('address-step').classList.add('active');
      document.getElementById('payment-step').classList.remove('active');
    }

    function confirmAddress() {
      const address = document.getElementById('address').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const date = document.getElementById('deliveryDate').value;
      let valid = true;

      // Очищаем ошибки
      document.getElementById('address-group').classList.remove('error');
      document.getElementById('address-error').classList.remove('show');
      document.getElementById('phone-group').classList.remove('error');
      document.getElementById('phone-error').classList.remove('show');
      document.getElementById('date-group').classList.remove('error');
      document.getElementById('date-error').classList.remove('show');

      // Валидируем адрес
      if (!address) {
        document.getElementById('address-group').classList.add('error');
        document.getElementById('address-error').classList.add('show');
        valid = false;
      }

      if (!/^\+7 \(\d{3}\) \d{3}-\d{2}-\d{2}$/.test(phone)) {
        document.getElementById('phone-group').classList.add('error');
        document.getElementById('phone-error').classList.add('show');
        valid = false;
      }

      // Валидируем дату
      if (!date) {
        document.getElementById('date-group').classList.add('error');
        document.getElementById('date-error').classList.add('show');
        valid = false;
      }

      if (valid) {
        document.getElementById('address-step').classList.remove('active');
        document.getElementById('payment-step').classList.add('active');
      }
    }

    function backToAddress() {
      document.getElementById('payment-step').classList.remove('active');
      document.getElementById('address-step').classList.add('active');
    }

    document.getElementById('payment-method').addEventListener('change', function() {
      const cardDetails = document.getElementById('card-details');
      if (this.value === 'card') {
        cardDetails.style.display = 'block';
      } else {
        cardDetails.style.display = 'none';
      }
    });

    document.getElementById('card-number').addEventListener('input', function(e) {
      let value = e.target.value.replace(/\D/g, '');
      if (value.length > 16) {
        value = value.substring(0, 16);
      }
      e.target.value = value.replace(/(\d{4})(?=\d)/g, '$1 ').trim();
    });

    document.getElementById('card-expiry').addEventListener('input', function(e) {
      let value = e.target.value.replace(/\D/g, '');
      if (value.length > 2) {
        value = value.substring(0, 2) + '/' + value.substring(2, 4);
      }
      e.target.value = value;
    });

    document.getElementById('card-cvc').addEventListener('input', function(e) {
      let value = e.target.value.replace(/\D/g, '');
      if (value.length > 3) {
        value = value.substring(0, 3);
      }
      e.target.value = value;
    });

    document.getElementById('phone').addEventListener('input', function(e) {
      let digits = e.target.value.replace(/\D/g, '');
      if (digits.startsWith('8')) digits = '7' + digits.slice(1);
      if (!digits.startsWith('7')) digits = '7' + digits;
      digits = digits.slice(0, 11);

      const p = digits.slice(1);
      let formatted = '+7';
      if (p.length > 0) formatted += ' (' + p.slice(0, 3);
      if (p.length >= 3) formatted += ')';
      if (p.length > 3) formatted += ' ' + p.slice(3, 6);
      if (p.length > 6) formatted += '-' + p.slice(6, 8);
      if (p.length > 8) formatted += '-' + p.slice(8, 10);
      e.target.value = formatted;
    });

    function isCardExpiryValid(cardExpiry) {
      if (!/^\d{2}\/\d{2}$/.test(cardExpiry)) return false;
      const [m, y] = cardExpiry.split('/').map(Number);
      if (m < 1 || m > 12) return false;
      const now = new Date();
      const curYear = now.getFullYear() % 100;
      const curMonth = now.getMonth() + 1;
      if (y < curYear) return false;
      if (y === curYear && m < curMonth) return false;
      return true;
    }

    async function confirmPayment() {
      const address = document.getElementById('address').value.trim();
      const date = document.getElementById('deliveryDate').value;
      const paymentMethod = document.getElementById('payment-method').value;
      let valid = true;

      // Очищаем ошибки
      document.getElementById('payment-group').classList.remove('error');
      document.getElementById('payment-error').classList.remove('show');
      document.getElementById('card-number-error').classList.remove('show');
      document.getElementById('card-expiry-error').classList.remove('show');
      document.getElementById('card-cvc-error').classList.remove('show');
      document.getElementById('card-number').parentElement.classList.remove('error');
      document.getElementById('card-expiry').parentElement.classList.remove('error');
      document.getElementById('card-cvc').parentElement.classList.remove('error');

      // Валидируем способ оплаты
      if (!paymentMethod) {
        document.getElementById('payment-group').classList.add('error');
        document.getElementById('payment-error').classList.add('show');
        valid = false;
      }

      // Если выбрана карта - валидируем данные
      if (paymentMethod === 'card') {
        const cardNumber = document.getElementById('card-number').value.replace(/\s/g, '');
        const cardExpiry = document.getElementById('card-expiry').value;
        const cardCvc = document.getElementById('card-cvc').value;

        if (!/^\d{16}$/.test(cardNumber)) {
          document.getElementById('card-number').parentElement.classList.add('error');
          document.getElementById('card-number-error').classList.add('show');
          valid = false;
        }

        if (!isCardExpiryValid(cardExpiry)) {
          document.getElementById('card-expiry').parentElement.classList.add('error');
          document.getElementById('card-expiry-error').classList.add('show');
          valid = false;
        }

        if (!/^\d{3}$/.test(cardCvc)) {
          document.getElementById('card-cvc').parentElement.classList.add('error');
          document.getElementById('card-cvc-error').classList.add('show');
          valid = false;
        }
      }

      if (!valid) {
        return;
      }
      
      try {
        const response = await fetch('/order/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ address, deliveryDate: date })
        });
        
        const data = await response.json();
        
        if (data.success) {
          document.getElementById('checkout-form').classList.remove('active');
          document.getElementById('order-id').textContent = data.orderId;
          document.getElementById('success-message').classList.add('active');
        }
      } catch (error) {
      }
    }

    const today = new Date().toISOString().split('T')[0];
    const deliveryDateInput = document.getElementById('deliveryDate');
    if (deliveryDateInput) {
      deliveryDateInput.min = today;
    }
  </script>
</body>
</html>
