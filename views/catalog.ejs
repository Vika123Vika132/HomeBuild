<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Каталог - Florist</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Каталог цветов</h2>
      <div class="grid">
        <% flowers.forEach(flower => { %>
          <div class="card">
            <img src="<%= flower.image_url %>" alt="<%= flower.name %>">
            <h3><%= flower.name %></h3>
            <p><%= flower.description %></p>
            <div class="price"><%= flower.price %> ₽</div>
            <p style="color: #999; font-size: 0.9rem;">В наличии: <%= flower.stock %> шт.</p>
            <a href="/product/<%= flower.id %>" class="btn btn-secondary">Подробнее</a>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
